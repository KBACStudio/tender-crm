generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubjectType {
  construction_company
  engineering_company
  professional_studio
  consultant
  other
}

enum OperatorType {
  company
  professional
}

enum PersonCompanyRole {
  administrator
  employee
  consultant
  contact
  legal_representative
  technical_director
  other
}

enum DesignLevel {
  PFTE
  final_design
  executive_design
  CSP
  CSE
  works_management
  testing
  other
}

enum TenderOutcome {
  draft
  submitted
  awarded
  lost
  cancelled
  unknown
}

enum GroupMemberRole {
  leader
  member
  consultant
  designer
  young_professional
  other
}

enum TenderTaskStatus {
  todo
  doing
  done
}

enum TenderTaskArea {
  administrative
  technical_offer
  economic_offer
  rtp
  general
}

model Company {
  id          String      @id @default(cuid())
  name        String
  subjectType SubjectType @default(other)
  vatNumber   String?
  fiscalCode  String?
  email       String?
  pec         String?
  phone       String?
  website     String?
  address     String?
  city        String?
  province    String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  operator       EconomicOperator?
  people         PersonCompany[]
  certifications Certification[]
  soaCertificates SoaCertificate[]
  documents      Document[]
  notesList      Note[]

  @@index([name])
  @@index([subjectType])
}

model Person {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  pec       String?
  phone     String?
  fiscalCode String?
  birthPlace String?
  birthDate DateTime?
  residenceAddress String?
  educationTitle String?
  university String?
  graduationDate DateTime?
  qualificationDate DateTime?
  professionalOrder String?
  professionalOrderProvince String?
  professionalOrderNumber String?
  professionalOrderRegistrationDate DateTime?
  inarcassaNumber String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies    PersonCompany[]
  operators    PersonOperator[]
  professional Professional?
  personalCertifications PersonalCertification[]
  documents    Document[]
  notesList    Note[]

  @@index([lastName, firstName])
}

model PersonCompany {
  id        String            @id @default(cuid())
  personId  String
  companyId String
  role      PersonCompanyRole @default(contact)
  title     String?
  startDate DateTime?
  endDate   DateTime?
  notes     String?

  person  Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([personId, companyId, role])
  @@index([companyId])
  @@index([personId])
}

model Professional {
  id             String   @id @default(cuid())
  personId       String   @unique
  register       String?
  registerNumber String?
  specialization String?
  vatNumber      String?
  insured        Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  operator     EconomicOperator?
  person       Person              @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model PersonalCertification {
  id        String   @id @default(cuid())
  personId  String
  name      String
  issuedAt  DateTime?
  expiresAt DateTime?
  notes     String?

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([name])
}

model EconomicOperator {
  id             String       @id @default(cuid())
  displayName    String
  operatorType   OperatorType
  companyId      String?      @unique
  professionalId String?      @unique
  notes          String?
  availableForAvvalimento Boolean @default(false)
  tags           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company      Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  professional Professional?  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  revenues     RevenueHistory[]
  services     ServiceAssignment[]
  groupMembers GroupMember[]
  tenderTasks  TenderTask[]
  people       PersonOperator[]
  certifications Certification[]

  @@index([displayName])
  @@index([operatorType])
}

model RevenueHistory {
  id         String   @id @default(cuid())
  operatorId String
  year       Int
  revenue    Decimal  @db.Decimal(14, 2)
  source     String?
  notes      String?
  createdAt  DateTime @default(now())

  operator EconomicOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([operatorId, year])
  @@index([year])
}

model PersonOperator {
  id         String            @id @default(cuid())
  personId   String
  operatorId String
  role       PersonCompanyRole @default(contact)
  title      String?
  startDate  DateTime?
  endDate    DateTime?
  notes      String?

  person   Person           @relation(fields: [personId], references: [id], onDelete: Cascade)
  operator EconomicOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([personId, operatorId, role])
  @@index([operatorId])
  @@index([personId])
}

model Certification {
  id            String    @id @default(cuid())
  operatorId    String
  companyId     String?
  type          String
  number        String?
  issuingBody   String?
  issuedAt      DateTime?
  expiresAt     DateTime?
  notes         String?
  availableForAvvalimento Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  operator EconomicOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([operatorId])
  @@index([companyId])
  @@index([expiresAt])
}

model SoaCertificate {
  id          String   @id @default(cuid())
  companyId   String
  certificateNumber String?
  issuingBody String?
  issuedAt    DateTime?
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  qualifications SoaQualification[]

  @@index([companyId])
  @@index([expiresAt])
}

model SoaQualification {
  id               String @id @default(cuid())
  soaCertificateId String
  category         String
  ranking          String
  notes            String?

  certificate SoaCertificate @relation(fields: [soaCertificateId], references: [id], onDelete: Cascade)

  @@index([soaCertificateId])
  @@index([category])
  @@index([ranking])
}

model WorkReference {
  id          String @id @default(cuid())
  code        String @unique
  category    String?
  description String?
  notes       String?

  serviceItems       ServiceWorkItem[]
  tenderRequirements TenderWorkRequirement[]

  @@index([code])
  @@index([category])
}

model Service {
  id          String      @id @default(cuid())
  title       String
  client      String?
  feeAmount   Decimal?    @db.Decimal(14, 2)
  startedAt   DateTime?
  endedAt     DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  assignments ServiceAssignment[]
  workItems   ServiceWorkItem[]
  levels      ServiceDesignLevel[]
  documents   Document[]
  notesList   Note[]
}

model ServiceAssignment {
  id             String @id @default(cuid())
  serviceId      String
  operatorId     String?
  role           String?
  executionPercent Decimal? @db.Decimal(5, 2)
  notes          String?

  service  Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  operator EconomicOperator? @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([operatorId])
}

model ServiceWorkItem {
  id           String   @id @default(cuid())
  serviceId    String
  workReferenceId String?
  workId       String
  workCategory String?
  workValue    Decimal? @db.Decimal(14, 2)
  sharePercent Decimal? @db.Decimal(5, 2)
  notes        String?

  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  workReference WorkReference? @relation(fields: [workReferenceId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([workReferenceId])
  @@index([workId])
  @@index([workCategory])
}

model ServiceDesignLevel {
  id        String      @id @default(cuid())
  serviceId String
  level     DesignLevel

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, level])
  @@index([level])
}

model Tender {
  id               String        @id @default(cuid())
  object           String
  cig              String        @unique
  cup              String?
  place            String?
  contractingBody  String?
  value            Decimal?      @db.Decimal(14, 2)
  publishedAt      DateTime?
  deadline         DateTime?
  outcome          TenderOutcome @default(draft)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  grouping Grouping?
  workRequirements TenderWorkRequirement[]
  soaRequirements  TenderSoaRequirement[]
  documents    Document[]
  notesList    Note[]
  tasks        TenderTask[]

  @@index([cig])
  @@index([place])
  @@index([contractingBody])
  @@index([deadline])
}

model TenderTask {
  id          String           @id @default(cuid())
  tenderId    String
  operatorId  String?
  title       String
  area        TenderTaskArea   @default(general)
  status      TenderTaskStatus @default(todo)
  dueDate     DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tender   Tender            @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  operator EconomicOperator? @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([tenderId])
  @@index([operatorId])
  @@index([status])
  @@index([dueDate])
}

model Grouping {
  id        String   @id @default(cuid())
  tenderId  String   @unique
  name      String
  type      String   @default("RTI")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      GroupMember[]
  tender       Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}

model GroupMember {
  id             String          @id @default(cuid())
  groupingId     String
  operatorId     String?
  role           GroupMemberRole @default(member)
  sharePercent   Decimal?        @db.Decimal(5, 2)
  notes          String?

  grouping Grouping          @relation(fields: [groupingId], references: [id], onDelete: Cascade)
  operator EconomicOperator? @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([groupingId])
  @@index([operatorId])
}

model TenderWorkRequirement {
  id        String   @id @default(cuid())
  tenderId  String
  workReferenceId String?
  workId    String
  category  String?
  amount    Decimal? @db.Decimal(14, 2)
  notes     String?

  tender        Tender         @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  workReference WorkReference? @relation(fields: [workReferenceId], references: [id], onDelete: SetNull)

  @@index([tenderId])
  @@index([workReferenceId])
  @@index([workId])
  @@index([category])
}

model TenderSoaRequirement {
  id        String   @id @default(cuid())
  tenderId  String
  category  String
  ranking   String?
  notes     String?

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId])
  @@index([category])
}

model Document {
  id             String   @id @default(cuid())
  title          String
  url            String?
  companyId      String?
  personId       String?
  serviceId      String?
  tenderId       String?
  notes          String?
  createdAt      DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person  Person?  @relation(fields: [personId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tender  Tender?  @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  body      String
  companyId String?
  personId  String?
  serviceId String?
  tenderId  String?
  createdAt DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person  Person?  @relation(fields: [personId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tender  Tender?  @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}
